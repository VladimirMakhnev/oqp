# O2 triplet UHF M_S=+1, smoothness re-check (near-degenerate pi*)
# reference, BHHLYP/6-31G(d). Bent triplet (C-H ~1.08 A, angle ~133 deg).
[input]
system=
 O   0.0000000000   0.0000000000   0.0000000000
 O   0.0000000000   0.0000000000   1.2100000000
charge=0
method=tdhf
runtype=energy
functional=bhhlyp
basis=6-31g*

[guess]
type=huckel
save_mol=false

[scf]
type=uhf
multiplicity=3
converger_type=diis
maxit=200
conv=1.0e-9

[dftgrid]
rad_npts=96
ang_npts=302

[tdhf]
type=umrsf
nstate=5
multiplicity=1
conv=1.0e-9
zvconv=1.0e-10
